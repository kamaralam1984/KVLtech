generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ADMINS — KVL TECH internal team
// ─────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      AdminRole @default(SUPPORT)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  DEVELOPER
}

// ─────────────────────────────────────────────
// CLIENTS — portal users (buyers)
// ─────────────────────────────────────────────
model Client {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  password     String
  company      String?
  city         String?
  isActive           Boolean   @default(true)
  emailVerified      Boolean   @default(false)
  verificationToken  String?
  verificationExpiry DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orders              Order[]
  brandingSubmissions BrandingSubmission[]
  supportTickets      SupportTicket[]
  notifications       Notification[]
  reviews             Review[]
  contactLeads        ContactLead[]
  subscriptions        Subscription[]
  referrals            Referral[]
  passwordResetTokens  PasswordResetToken[]

  @@map("clients")
}

// ─────────────────────────────────────────────
// PRODUCTS — website & software catalog
// ─────────────────────────────────────────────
model Product {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  tagline      String
  description  String      @db.Text
  category     ProductCategory
  photo        String
  gallery      String[]
  basicPrice   Int
  premiumPrice Int
  isActive     Boolean     @default(true)
  tag          String?
  techStack    String[]
  deliverables String[]
  highlights   String[]
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  plans  ProductPlan[]
  faqs   ProductFaq[]
  orders Order[]

  @@map("products")
}

enum ProductCategory {
  WEBSITE
  SOFTWARE
  SAAS
  MOBILE
}

model ProductPlan {
  id        String   @id @default(cuid())
  productId String
  name      PlanType
  price     String
  delivery  String
  support   String
  features  String[]
  sortOrder Int      @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_plans")
}

model ProductFaq {
  id        String @id @default(cuid())
  productId String
  question  String
  answer    String @db.Text
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_faqs")
}

enum PlanType {
  BASIC
  PREMIUM
  CUSTOM
}

// ─────────────────────────────────────────────
// ORDERS — purchase records
// ─────────────────────────────────────────────
model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  clientId    String
  productId   String
  plan        PlanType
  status      OrderStatus @default(PAYMENT_PENDING)
  progress    Int         @default(0)
  amount      Int
  currency    String      @default("INR")
  notes       String?     @db.Text
  deliveryEst DateTime?
  deliveredAt DateTime?
  liveUrl     String?
  filesUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  client   Client  @relation(fields: [clientId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  payment  Payment?
  branding BrandingSubmission?
  review   Review?
  statusHistory   OrderStatusHistory[]
  tickets         SupportTicket[]
  messages        Message[]
  projectFiles    ProjectFile[]
  designApprovals DesignApproval[]

  @@map("orders")
}

enum OrderStatus {
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  DESIGN_STARTED
  DEVELOPMENT
  REVIEW_TESTING
  DELIVERED
  CANCELLED
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// ─────────────────────────────────────────────
// PAYMENTS — Razorpay / Stripe records
// ─────────────────────────────────────────────
model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  gateway           String        @default("razorpay")
  gatewayOrderId    String?
  gatewayPaymentId  String?
  gatewaySignature  String?
  method            String?
  paidAt            DateTime?
  failureReason     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// BRANDING SUBMISSIONS — client branding details
// ─────────────────────────────────────────────
model BrandingSubmission {
  id             String           @id @default(cuid())
  orderId        String?          @unique
  clientId       String
  companyName    String
  tagline        String?
  primaryColor   String           @default("#C9A227")
  secondaryColor String           @default("#0F172A")
  fontPreference String?
  phone          String?
  email          String?
  address        String?
  website        String?
  logoNote       String?          @db.Text
  logoUrl        String?
  status         BrandingStatus   @default(SUBMITTED)
  appliedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  order  Order?  @relation(fields: [orderId], references: [id])
  client Client  @relation(fields: [clientId], references: [id])

  @@map("branding_submissions")
}

enum BrandingStatus {
  SUBMITTED
  UNDER_REVIEW
  APPLIED
  REVISION_NEEDED
}

// ─────────────────────────────────────────────
// SUPPORT TICKETS
// ─────────────────────────────────────────────
model SupportTicket {
  id       String         @id @default(cuid())
  ticketNo String         @unique
  clientId String
  orderId  String?
  subject  String
  message  String         @db.Text
  priority TicketPriority @default(MEDIUM)
  status   TicketStatus   @default(OPEN)
  closedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client  Client          @relation(fields: [clientId], references: [id])
  order   Order?          @relation(fields: [orderId], references: [id])
  replies TicketReply[]

  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  authorType String  @default("client")
  message   String   @db.Text
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

// ─────────────────────────────────────────────
// CONTACT LEADS — website contact form
// ─────────────────────────────────────────────
model ContactLead {
  id         String     @id @default(cuid())
  clientId   String?
  name       String
  phone      String
  email      String?
  service    String?
  budget     String?
  message    String?    @db.Text
  source     String     @default("contact_form")
  status     LeadStatus @default(NEW)
  notes      String?    @db.Text
  followUpAt DateTime?
  score      Int        @default(0)
  scoreLabel String     @default("cold")
  scoreNote  String?    @db.Text
  scoredAt   DateTime?
  assignedTo String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  client     Client?    @relation(fields: [clientId], references: [id])
  activities Activity[]

  @@map("contact_leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

// ─────────────────────────────────────────────
// NOTIFICATIONS — client bell notifications
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  clientId  String
  title     String
  body      String
  type      NotificationType @default(INFO)
  color     String           @default("#C9A227")
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ORDER_UPDATE
  PAYMENT
  BRANDING
  SUPPORT
}

// ─────────────────────────────────────────────
// REVIEWS — order star ratings
// ─────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  orderId   String   @unique
  clientId  String
  rating    Int
  title     String?
  comment   String?  @db.Text
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  order  Order  @relation(fields: [orderId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@map("reviews")
}

// ─────────────────────────────────────────────
// BLOG POSTS
// ─────────────────────────────────────────────
model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String     @db.Text
  content     String     @db.Text
  category    String
  photo       String
  author      String
  authorRole  String?
  readTime    String?
  isFeatured  Boolean    @default(false)
  isPublished Boolean    @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("blog_posts")
}

// ─────────────────────────────────────────────
// CAMPAIGNS — marketing broadcasts
// ─────────────────────────────────────────────
model Campaign {
  id           String         @id @default(cuid())
  name         String
  type         CampaignType
  subject      String?
  message      String         @db.Text
  recipients   String         @default("ALL_LEADS")
  status       CampaignStatus @default(DRAFT)
  sentCount    Int            @default(0)
  openCount    Int            @default(0)
  clickCount   Int            @default(0)
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdBy    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("campaigns")
}

enum CampaignType {
  EMAIL
  WHATSAPP
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// JOB APPLICATIONS — careers form submissions
// ─────────────────────────────────────────────
model JobApplication {
  id          String            @id @default(cuid())
  name        String
  email       String
  phone       String
  position    String
  experience  String?
  portfolio   String?
  coverLetter String?           @db.Text
  resumeUrl   String?
  status      ApplicationStatus @default(PENDING)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("job_applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS — recurring billing
// ─────────────────────────────────────────────
model Subscription {
  id              String             @id @default(cuid())
  clientId        String
  planName        String
  amount          Int
  currency        String             @default("INR")
  billingCycle    String             @default("monthly")
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime           @default(now())
  nextBillingAt   DateTime?
  cancelledAt     DateTime?
  razorpaySubId   String?
  couponId        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  client  Client  @relation(fields: [clientId], references: [id])
  coupon  Coupon? @relation(fields: [couponId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────
// COUPONS — discount codes
// ─────────────────────────────────────────────
model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   @default("percent")
  discountValue Int
  maxUses       Int?
  usedCount     Int      @default(0)
  minOrderValue Int?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  referrerId    String?
  createdAt     DateTime @default(now())

  subscriptions Subscription[]

  @@map("coupons")
}

// ─────────────────────────────────────────────
// REFERRALS — affiliate / referral program
// ─────────────────────────────────────────────
model Referral {
  id               String         @id @default(cuid())
  referrerId       String
  refereeEmail     String
  refereeId        String?
  commission       Int            @default(0)
  commissionRate   Float          @default(20)
  level            Int            @default(1)
  parentReferralId String?
  couponId         String?
  couponCode       String?
  orderAmount      Int            @default(0)
  status           ReferralStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referrer  Client    @relation(fields: [referrerId], references: [id])
  children  Referral[] @relation("ReferralChain")
  parent    Referral?  @relation("ReferralChain", fields: [parentReferralId], references: [id])

  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  CONVERTED
  PAID
  REJECTED
}

// ─────────────────────────────────────────────
// ACTIVITIES — CRM activity timeline
// ─────────────────────────────────────────────
model Activity {
  id          String       @id @default(cuid())
  leadId      String
  type        ActivityType
  title       String
  description String?      @db.Text
  scheduledAt DateTime?
  completedAt DateTime?
  adminId     String?
  adminName   String?
  outcome     String?
  createdAt   DateTime     @default(now())

  lead ContactLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("activities")
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  NOTE
  TASK
}

// ─────────────────────────────────────────────
// MESSAGES — client ↔ admin portal chat
// ─────────────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  orderId     String
  senderId    String
  senderType  String   @default("client")
  senderName  String
  text        String   @db.Text
  fileUrl     String?
  fileName    String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─────────────────────────────────────────────
// PROJECT FILES — file sharing per order
// ─────────────────────────────────────────────
model ProjectFile {
  id           String   @id @default(cuid())
  orderId      String
  uploadedBy   String
  uploaderType String   @default("admin")
  uploaderName String
  name         String
  url          String
  size         Int?
  mimeType     String?
  category     String   @default("general")
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("project_files")
}

// ─────────────────────────────────────────────
// DESIGN APPROVALS — client approval workflow
// ─────────────────────────────────────────────
model DesignApproval {
  id          String         @id @default(cuid())
  orderId     String
  title       String
  description String?        @db.Text
  fileUrl     String?
  previewUrl  String?
  status      ApprovalStatus @default(PENDING)
  clientNote  String?        @db.Text
  respondedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("design_approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

// ─────────────────────────────────────────────
// AUDIT LOGS — admin action tracking
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  adminName  String?
  action     String
  resource   String
  resourceId String?
  details    String?  @db.Text
  ip         String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// AUTOMATION RULES — trigger-based marketing
// ─────────────────────────────────────────────
model AutomationRule {
  id           String   @id @default(cuid())
  name         String
  trigger      String
  triggerValue String?
  action       String
  channel      String   @default("email")
  template     String?  @db.Text
  delayHours   Int      @default(0)
  isActive     Boolean  @default(true)
  runCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("automation_rules")
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKENS
// ─────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  clientId  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ═══════════════════════════════════════════════════
// ENTERPRISE UPGRADE — Phase 1-5
// ═══════════════════════════════════════════════════

// ─────────────────────────────────────────────
// RBAC — Custom Roles & Permissions
// ─────────────────────────────────────────────
model CustomRole {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  color        String   @default("#6366F1")
  isSystem     Boolean  @default(false)
  department   String?
  parentRoleId String?
  createdAt    DateTime @default(now())

  permissions RolePermission[]
  admins      AdminRoleAssignment[]
  children    CustomRole[]  @relation("RoleHierarchy")
  parent      CustomRole?   @relation("RoleHierarchy", fields: [parentRoleId], references: [id])

  @@map("custom_roles")
}

model Permission {
  id          String           @id @default(cuid())
  module      String
  action      PermissionAction
  description String?

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AdminRoleAssignment {
  id        String   @id @default(cuid())
  adminId   String
  roleId    String
  createdAt DateTime @default(now())

  role CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([adminId, roleId])
  @@map("admin_role_assignments")
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  EXPORT
  MANAGE
}

// ─────────────────────────────────────────────
// API KEYS — Developer Platform
// ─────────────────────────────────────────────
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  prefix      String
  adminId     String
  scopes      String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  requestCount Int      @default(0)
  createdAt   DateTime  @default(now())

  logs ApiKeyLog[]

  @@map("api_keys")
}

model ApiKeyLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  endpoint  String
  method    String
  status    Int
  ip        String?
  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@map("api_key_logs")
}

// ─────────────────────────────────────────────
// WEBHOOKS — Outgoing Custom Webhooks
// ─────────────────────────────────────────────
model WebhookEndpoint {
  id          String   @id @default(cuid())
  name        String
  url         String
  secret      String?
  events      String[]
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id             String          @id @default(cuid())
  endpointId     String
  event          String
  payload        String          @db.Text
  responseStatus Int?
  responseBody   String?         @db.Text
  status         WebhookStatus   @default(PENDING)
  attempts       Int             @default(0)
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime        @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}

enum WebhookStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

// ─────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────
model KBCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  articles KBArticle[]

  @@map("kb_categories")
}

model KBArticle {
  id           String    @id @default(cuid())
  categoryId   String?
  title        String
  slug         String    @unique
  content      String    @db.Text
  excerpt      String?
  isPublic     Boolean   @default(true)
  isPublished  Boolean   @default(false)
  viewCount    Int       @default(0)
  helpfulCount Int       @default(0)
  tags         String[]
  authorName   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category KBCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("kb_articles")
}

// ─────────────────────────────────────────────
// SLA POLICIES
// ─────────────────────────────────────────────
model SLAPolicy {
  id                    String   @id @default(cuid())
  name                  String
  priority              String
  firstResponseMinutes  Int
  resolutionMinutes     Int
  escalationMinutes     Int?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  @@map("sla_policies")
}

model TicketSLALog {
  id                    String    @id @default(cuid())
  ticketId              String    @unique
  slaId                 String?
  firstResponseAt       DateTime?
  resolvedAt            DateTime?
  firstResponseBreached Boolean   @default(false)
  resolutionBreached    Boolean   @default(false)
  escalatedAt           DateTime?
  createdAt             DateTime  @default(now())

  @@map("ticket_sla_logs")
}

// ─────────────────────────────────────────────
// MEETING SCHEDULER — Calendly-style
// ─────────────────────────────────────────────
model MeetingAvailability {
  id          String  @id @default(cuid())
  adminId     String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isActive    Boolean @default(true)
  timezone    String  @default("Asia/Kolkata")

  @@unique([adminId, dayOfWeek, startTime])
  @@map("meeting_availability")
}

model MeetingBooking {
  id           String        @id @default(cuid())
  adminId      String
  clientName   String
  clientEmail  String
  clientPhone  String?
  date         DateTime
  duration     Int           @default(30)
  title        String        @default("Consultation Call")
  notes        String?
  meetingLink  String?
  status       BookingStatus @default(PENDING)
  reminderSent Boolean       @default(false)
  cancelReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("meeting_bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ─────────────────────────────────────────────
// E-SIGNATURE
// ─────────────────────────────────────────────
model SignatureRequest {
  id          String          @id @default(cuid())
  title       String
  description String?
  documentUrl String?
  content     String?         @db.Text
  status      SignatureStatus @default(PENDING)
  createdBy   String
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  signatories Signatory[]

  @@map("signature_requests")
}

model Signatory {
  id          String    @id @default(cuid())
  requestId   String
  name        String
  email       String
  role        String    @default("signer")
  signatureData String? @db.Text
  signedAt    DateTime?
  ipAddress   String?
  token       String    @unique @default(cuid())
  status      SignatureStatus @default(PENDING)

  request SignatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("signatories")
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

